{
  "name": "vidbee",
  "private": true,
  "scripts": {
    "check": "pnpm --filter ./apps/desktop run check",
    "check:i18n": "pnpm --filter ./apps/desktop run check:i18n",
    "typecheck": "pnpm --filter ./apps/desktop run typecheck",
    "dev": "pnpm --filter ./apps/desktop run dev",
    "dev:update-notice": "pnpm --filter ./apps/desktop run dev:update-notice",
    "start": "pnpm --filter ./apps/desktop run start",
    "build": "pnpm --filter ./apps/desktop run build",
    "setup": "pnpm --filter ./apps/desktop run setup",
    "build:unpack": "pnpm --filter ./apps/desktop run build:unpack",
    "build:win": "pnpm --filter ./apps/desktop run build:win",
    "build:mac": "pnpm --filter ./apps/desktop run build:mac",
    "build:linux": "pnpm --filter ./apps/desktop run build:linux",
    "release": "pnpm --filter ./apps/desktop run release",
    "db:generate": "pnpm --filter ./apps/desktop run db:generate",
    "db:migrate": "pnpm --filter ./apps/desktop run db:migrate",
    "fix": "pnpm --filter ./apps/desktop run fix",
    "dev:desktop": "pnpm --filter ./apps/desktop run dev",
    "build:desktop": "pnpm --filter ./apps/desktop run build",
    "dev:api": "pnpm --filter ./apps/api run dev",
    "start:api": "pnpm --filter ./apps/api run start",
    "check:api": "pnpm --filter ./apps/api run check",
    "dev:web": "pnpm --filter ./apps/web run dev",
    "start:web": "pnpm -r --parallel --filter ./apps/api --filter ./apps/web run dev",
    "build:web": "pnpm --filter ./apps/web run build",
    "check:web": "pnpm --filter ./apps/web run check",
    "dev:docs": "pnpm --filter ./apps/docs dev",
    "build:docs": "pnpm --filter ./apps/docs build",
    "dev:extension": "pnpm --filter ./apps/extension dev",
    "build:extension": "pnpm --filter ./apps/extension build",
    "zip:extension": "pnpm --filter ./apps/extension zip",
    "prepare": "husky"
  },
  "devDependencies": {
    "@svgr/core": "^8.1.0",
    "@svgr/plugin-jsx": "^8.1.0",
    "electron": "^38.3.0",
    "husky": "^9.1.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ],
    "overrides": {
      "@orpc/client": ">=1.14.0 <2",
      "@orpc/contract": ">=1.14.0 <2",
      "@orpc/openapi": ">=1.14.0 <2",
      "@orpc/server": ">=1.14.0 <2",
      "@orpc/zod": ">=1.14.0 <2",
      "electron": ">=39.8.5 <40",
      "undici": ">=7.24.0 <8",
      "vite": ">=7.3.2 <8",
      "rollup": ">=4.59.0 <5",
      "next": ">=16.2.3",
      "react-router": ">=7.12.0 <8",
      "h3": ">=2.0.1-rc.18",
      "h3-v2": "npm:h3@>=2.0.1-rc.18",
      "better-sqlite3": ">=12.9.0 <13",
      "drizzle-orm": ">=0.45.2 <0.46",
      "fastify": ">=5.8.5 <6",
      "minimatch": ">=10.2.3",
      "picomatch@2": ">=2.3.2 <3",
      "picomatch@4": ">=4.0.4 <5",
      "path-to-regexp": ">=8.4.0",
      "postcss": ">=8.5.10 <9",
      "yaml": ">=2.8.3",
      "brace-expansion": ">=5.0.5",
      "ajv@6": ">=6.14.0 <7",
      "ajv@8": ">=8.18.0 <9",
      "srvx": ">=0.11.13",
      "@xmldom/xmldom": ">=0.8.13",
      "defu": ">=6.1.5 <7",
      "glob": ">=10.5.0",
      "lodash": ">=4.18.0",
      "node-forge": ">=1.4.0",
      "tar": ">=7.5.11 <8",
      "esbuild": ">=0.25.0",
      "@tootallnate/once": ">=3.0.1"
    }
  }
}
